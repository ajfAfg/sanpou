mod factorial {
  var x = 0;

  property testing = finally(x == 120);

  procedure fact(x) {
    if (x == 0) {
      return 1;
    } else {
      var ans = x * fact(x-1);
      return ans;
    }
  }

  procedure worker() {
    x = fact(5);
    return ();
  }

  fair process workers(self in {1}) = worker;
}
