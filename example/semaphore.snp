mod semaphore {
    def num = 2;
    def threadsNum = 2;

    var cnt = 0;

    property convergence = globally(0 <= cnt) && globally(finally(cnt <= num));

    procedure semaphore() {
        while (true) {
            while (cnt >= num) {}
            cnt = cnt + 1;
            if (cnt <= num) {
                break;
            }
            cnt = cnt - 1;
        }
        return ();
    }

    fair process processes(self in 1..threadsNum) = semaphore;
}
